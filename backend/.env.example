# Скопируйте в .env и заполните реальными значениями (.env в git НЕ коммитится)

# ЮKassa — из личного кабинета магазина (https://yookassa.ru)
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# База данных. На Amvera с примонтированным диском /data:
# DATABASE_URL=sqlite+aiosqlite:////data/gospomoshnik.db
DATABASE_URL=sqlite+aiosqlite:///./gospomoshnik.db

# "test" — песочница ЮKassa, "production" — боевой режим
ENVIRONMENT=production
